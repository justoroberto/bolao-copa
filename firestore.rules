rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para checar se é admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Regra para Users:
    // Qualquer um logado pode ler rankings/users.
    // O próprio usuário pode criar/atualizar seus dados.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Nicknames:
    // Qualquer um pode ler para verificar disponibilidade antes do cadastro.
    // Apenas usuário logado pode criar o seu próprio nickname apontando para seu UID.
    match /nicknames/{nicknameId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Imutável
    }

    // Regra para Rankings:
    // O Ranking Global é público para qualquer visitante ler.
    match /rankings/{rankingId} {
      allow read: if true;
      allow write: if isAdmin(); // Admin atualiza via client side
    }

    // Regra para Matches (estáticos, mas se existissem):
    // Qualquer um logado pode ler.
    // Ninguém pode escrever pelo client.
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // Regra para MatchResults (resultados oficiais):
    // Todos podem ler os resultados.
    // Apenas admin pode inserir/alterar resultados.
    match /matchResults/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regra para Predictions (Palpites):
    // Qualquer um logado pode ler para montar o ranking.
    // Apenas o dono pode escrever, E apenas se faltar mais de 1 hora para o jogo.
    match /predictions/{predictionId} {
      allow read: if request.auth != null;
      
      // Checa se o userId que está sendo salvo é o mesmo do auth
      allow create, update: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      
      // Permitir delete antes do tempo, se necessário
      allow delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
    }

    // Regra para LeagueNames (usado para garantir unicidade do nome):
    // Qualquer um pode ler.
    // Qualquer logado pode criar. Sem update ou delete pelo client (apenas pelo cloud functions/admin se existir, 
    // mas vamos permitir delete pelo dono da liga se ele deletar a liga?
    // Como não há transaction fácil client-side, vamos simplificar.
    match /leagueNames/{nameId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      allow update: if false;
    }

    // Regra para Leagues:
    match /leagues/{leagueId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Atualização permitida para o admin (remover pessoas) ou pelo próprio usuário (entrar/sair).
      allow update: if request.auth != null;
      // Exclusão permitida apenas para o admin da liga.
      allow delete: if request.auth != null && resource.data.adminId == request.auth.uid;
    }
  }
}
